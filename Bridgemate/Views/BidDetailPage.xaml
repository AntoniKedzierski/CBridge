<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Bridgemate.Views.BidDetailPage"
             Title="Bid Details"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout x:Name="ContentStack" Padding="20,16" Spacing="0">

            <!-- Bid badge -->
            <Border x:Name="BidBadge"
                    StrokeThickness="2"
                    Padding="24,8"
                    Margin="0,0,0,4"
                    HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Label x:Name="BidBadgeLabel"
                       FontSize="40"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
            </Border>

            <!-- Bidder -->
            <Label x:Name="BidderLabel"
                   FontSize="13"
                   TextColor="#888888"
                   HorizontalOptions="Center"
                   Margin="0,0,0,12" />

            <!-- Description highlight box (shown when Description is present) -->
            <Border x:Name="DescriptionBox"
                    IsVisible="False"
                    BackgroundColor="#F0F7FF"
                    StrokeThickness="0"
                    Padding="14,10"
                    Margin="0,0,0,8">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="6" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="2">
                    <Label Text="Description"
                           FontSize="11"
                           TextColor="#1565C0"
                           FontAttributes="Bold"
                           CharacterSpacing="0.5" />
                    <Label x:Name="DescriptionLabel"
                           FontSize="15"
                           TextColor="#1A1A1A"
                           FontAttributes="Italic" />
                </VerticalStackLayout>
            </Border>

            <!-- Divider -->
            <BoxView HeightRequest="1" Color="#E8E8E8" Margin="0,4,0,8" />

            <!-- Details section (convention, condition, requirements, flags, ai source) -->
            <VerticalStackLayout x:Name="DetailsStack" Spacing="6" />

            <!-- Stack Trace section -->
            <BoxView x:Name="StackTraceDivider" HeightRequest="1" Color="#E8E8E8" Margin="0,8,0,8" IsVisible="False" />
            <VerticalStackLayout x:Name="StackTraceSection" IsVisible="False" Spacing="4">
                <Label Text="BID STACK TRACE"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="#888888"
                       CharacterSpacing="0.8"
                       Margin="0,0,0,4" />
                <!-- Bid path breadcrumb -->
                <FlexLayout x:Name="BidPathRow"
                            Wrap="Wrap"
                            Direction="Row"
                            AlignItems="Center"
                            Margin="0,0,0,6" />
                <!-- Raw .NET stack trace -->
                <Border BackgroundColor="#F8F8F8"
                        StrokeThickness="0"
                        Padding="12,8">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="4" />
                    </Border.StrokeShape>
                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Always">
                        <Label x:Name="RawStackTraceLabel"
                               FontSize="10"
                               TextColor="#555555"
                               FontFamily="Courier New"
                               LineBreakMode="NoWrap" />
                    </ScrollView>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
