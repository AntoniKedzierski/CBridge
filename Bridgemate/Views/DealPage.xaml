<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Bridgemate.Views.DealPage"
             Title="Deal Details"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="16,12" Spacing="0">

            <!-- Header info bar -->
            <Label x:Name="InfoLabel"
                   FontSize="13"
                   TextColor="#888888"
                   Margin="0,0,0,8" />

            <BoxView HeightRequest="1" Color="#E8E8E8" Margin="0,0,0,8" />

            <!-- HANDS section -->
            <Label Text="HANDS"
                   FontSize="11" FontAttributes="Bold"
                   TextColor="#888888" CharacterSpacing="0.8"
                   Margin="0,0,0,6" />

            <!-- Compass grid injected by code-behind -->
            <Grid x:Name="CompassContainer" Margin="0,0,0,4" />

            <BoxView HeightRequest="1" Color="#E8E8E8" Margin="0,8" />

            <!-- AUCTION section -->
            <Label Text="AUCTION"
                   FontSize="11" FontAttributes="Bold"
                   TextColor="#888888" CharacterSpacing="0.8"
                   Margin="0,0,0,6" />

            <!-- Auction grid injected by code-behind -->
            <Grid x:Name="AuctionContainer" Margin="0,0,0,4" />

            <BoxView HeightRequest="1" Color="#E8E8E8" Margin="0,8" />

            <!-- CONTRACT section -->
            <Label Text="CONTRACT"
                   FontSize="11" FontAttributes="Bold"
                   TextColor="#888888" CharacterSpacing="0.8"
                   Margin="0,0,0,6" />

            <Label x:Name="ContractLabel" FontSize="15" TextColor="#1A1A1A" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
