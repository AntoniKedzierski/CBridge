<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Bridgemate.Models"
             x:Class="Bridgemate.MainPage"
             x:Name="ThisPage"
             Title="Bridge Simulator"
             BackgroundColor="#F4F6F9">

    <!-- Responsive centering: content capped at 800px, centred when wider -->
    <Grid RowDefinitions="Auto,*">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="800" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Control panel card -->
        <Border Grid.Row="0" Grid.Column="1"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="20,16" Margin="20,16,20,8"
                StrokeShape="RoundRectangle 10">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,2" Radius="10" Opacity="0.08" />
            </Border.Shadow>
            <VerticalStackLayout Spacing="12">

                <Label Text="Bridge Simulator"
                       FontSize="24" FontAttributes="Bold"
                       HorizontalOptions="Center" />

                <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="12">
                    <Label Text="Number of Deals:"
                           VerticalOptions="Center" FontSize="15" />
                    <Entry Text="{Binding DealCount}"
                           WidthRequest="72"
                           Keyboard="Numeric"
                           HorizontalTextAlignment="Center"
                           FontSize="15"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <Button Text="Simulate"
                        Command="{Binding SimulateCommand}"
                        IsEnabled="{Binding CanSimulate}"
                        HorizontalOptions="Center"
                        WidthRequest="180" />

                <ActivityIndicator IsRunning="{Binding IsSimulating}"
                                   IsVisible="{Binding IsSimulating}"
                                   HorizontalOptions="Center" />

                <Label Text="{Binding ErrorMessage}"
                       IsVisible="{Binding HasError}"
                       TextColor="Red"
                       HorizontalOptions="Center"
                       FontSize="13" />

            </VerticalStackLayout>
        </Border>

        <!-- Deals list -->
        <CollectionView Grid.Row="1" Grid.Column="1"
                        Margin="20,0,20,16"
                        ItemsSource="{Binding Deals}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <Label Text="Run a simulation to see deals here."
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="{StaticResource Gray400}"
                       FontSize="15"
                       Margin="0,40" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:DealResult">
                    <Border Margin="0,4" Padding="16,12"
                            BackgroundColor="White"
                           
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,1" Radius="6" Opacity="0.07" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.OpenDealCommand}"
                                CommandParameter="{Binding}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="{Binding Summary}"
                                       FontSize="15" FontAttributes="Bold" />
                                <HorizontalStackLayout Spacing="16">
                                    <Label Text="{Binding Dealer, StringFormat='Dealer: {0}'}"
                                           FontSize="12"
                                           TextColor="{StaticResource Gray500}" />
                                    <Label Text="{Binding PointsSummary}"
                                           FontSize="12"
                                           TextColor="{StaticResource Gray500}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="&#x203A;"
                                   FontSize="22" VerticalOptions="Center"
                                   TextColor="{StaticResource Primary}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
